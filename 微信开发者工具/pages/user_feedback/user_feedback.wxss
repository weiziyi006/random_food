.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}
.feedback-list {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.feedback-item {
  padding: 25rpx 0;
  border-bottom: 1rpx solid #eee;
}
.feedback-item:last-child {
  border-bottom: none;
}
.feedback-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 15rpx;
}
.feedback-meta {
  font-size: 24rpx;
  color: #999;
}
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999;
}