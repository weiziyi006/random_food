page {
  background-color: #fff;
  color: #333;
}
.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
.content {
  width: 500rpx;
  height: 400rpx;
  padding: 30rpx 32rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  padding: 10px;
}
.input-area {
  width: 600rpx;
  height: 200rpx;
  background-color: #f9f9f9;
  border: 1rpx solid #eee;
  border-radius: 16rpx;
  padding: 32rpx;
  font-size: 28rpx;
  color: #999;
  line-height: 42rpx;
  margin-bottom: 45rpx;
}
.input-area::placeholder {
  color: #ccc;
  font-size: 26rpx;
}
.email-input {
  width: 640rpx;
  border: none;
  border-bottom: 1rpx solid #eee;
  outline: none;
  padding: 16rpx 10px;
  font-size: 28rpx;
  color: #333;
  background-color: transparent;
}
.email-input::placeholder {
  color: #ccc;
  font-size: 26rpx;
}
.submit-btn {
  width: 400rpx;
  height: 40rpx;
  background-color: #ffd100;
  color: #333;
  border: none;
  border-radius: 30rpx;
  padding: 32rpx;
  font-size: 35rpx;
  font-weight: 500;
  text-align: center;
  margin: 350rpx auto;
  line-height: 40rpx;
}