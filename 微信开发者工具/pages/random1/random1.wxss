.container {
  width: 100%;
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}
.title {
  position: relative;
  margin-bottom: 80rpx;
  z-index: 6;
  text-align: center;
}
.title-text1 {
  display: block;
  font-size: 64rpx;
  font-weight: 700;
  color: #5D4037;
  line-height: 1.4;
  text-shadow:5rpx 5rpx 9rpx rgba(0,0,0,0.4)
}
.title-text2 {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #5D4037;
  line-height: 1.4;
  text-shadow:4rpx 4rpx 8rpx rgba(0,0,0,0.4)
}
.cube-wrapper {
  position: relative;
  margin-bottom: 30rpx;
  z-index: 10;
}
.cube {
  width: 280rpx;
  height: 280rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 1s ease;
  margin: 0 auto;
}
.cube-face {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 4rpx solid #fff;
  border-radius: 12rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: rgb(219, 122, 12);
}
.front { transform: translateZ(140rpx); }
.right { transform: translateX(140rpx) rotateY(90deg); }
.left { transform: translateX(-140rpx) rotateY(-90deg); }
.back { transform: translateZ(-140rpx) rotateY(180deg); }
.top { transform: translateY(-140rpx) rotateX(90deg); }
.bottom { transform: translateY(140rpx) rotateX(-90deg); }
.cube-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
/* 3D旋转动画 */
@keyframes rotate-3d-anim {
  0% { transform: rotateY(0deg); }
  100% { transform: rotateY(360deg); }
}
.rotate-3d {
  animation: rotate-3d-anim 15s linear infinite;
}
.food-circle-container {
  position: absolute;
  width: 600rpx;
  height: 600rpx;
  z-index: 4;
  pointer-events: none;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  margin-top: -20rpx;
}
.float-food-item {
  position: absolute;
  font-size: 40rpx;
  font-weight: bold;
  color: #5D4037;
  width: 60rpx;
  height: 60rpx;
  text-align: center;
  animation: float-up-down 4s ease-in-out infinite;
  transform-origin: center;
  pointer-events: auto; 
}
.item-0 {animation-delay: 0s; }
.item-1 {animation-delay: 0.3s; }
.item-2 {animation-delay: 0.6s; }
.item-3 {animation-delay: 0.9s; }
.item-4 {animation-delay: 0.2s; }
.item-5 {animation-delay: 0.5s; }
.item-6 {animation-delay: 0.8s; }
.item-7 {animation-delay: 0.1s; }
/* 图标漂浮动画 */
@keyframes float-up-down {
  0% { transform: translateY(0rpx) rotate(0deg); }
  50% { transform: translateY(-20rpx) rotate(5deg); }
  100% { transform: translateY(0rpx) rotate(0deg); }
}
/* 盒子光效 */
.cube-light {
  position: absolute;
  width: 340rpx;
  height: 340rpx;
  background: radial-gradient(circle, rgba(255,240,160,0.8) 0%, rgba(255,193,7,0.3) 60%, transparent 100%);
  border-radius: 50%;
  z-index: 1;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: light-pulse 3s ease-in-out infinite;
  pointer-events: none;
}
.cube-light-second {
  width: 420rpx;
  height: 420rpx;
  background: radial-gradient(circle, rgba(255,224,128,0.3) 0%, rgba(255,179,0,0.1) 60%, transparent 100%);
  animation-delay: 1s;
  z-index: 0;
}
@keyframes light-pulse {
  0% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.4; transform: translate(-50%, -50%) scale(1.05); }
  100% { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
}
/* 按钮 */
.open-btn {
  width: 160rpx;
  height: 80rpx;
  background: #ffb700;
  border: none;
  border-radius: 40rpx;
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 6;
  margin-top: 20rpx;
  animation: flash 1.2s infinite;
  pointer-events: auto;
  position: relative;
}
@keyframes flash {
  0% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.05); }
  100% { opacity: 1; transform: scale(1); }
}