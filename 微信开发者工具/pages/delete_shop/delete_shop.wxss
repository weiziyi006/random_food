/* 全局样式重置 */
page {
  background-color: #FFF9F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
.container {
  padding: 20rpx;
  min-height: 100vh;
}
/* 页面标题 */
.page-header {
  margin-bottom: 30rpx;
  text-align: center;
}
.title {
  font-size: 42rpx;
  font-weight: bold;
  color: #FF7A2F;
}
/* 搜索栏 */
.search-container {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 50rpx;
  padding: 15rpx 25rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(255, 122, 47, 0.1);
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}
.search-icon {
  margin-left: 15rpx;
}
/* 列表样式 */
.shop-list {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 15rpx rgba(255, 122, 47, 0.08);
}
.checkbox-wrapper {
  z-index: 9999;
  position: relative;
  margin-right: 20rpx;
}
.shop-item-checked {
  background-color: #FFF5F0;
  border-left: 4rpx solid #FF7A2F;
}

.shop-item {
  display: flex;
  align-items: center;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
  transition: background-color 0.3s;
}
.shop-item:last-child {
  border-bottom: none;
}
.shop-item:active {
  background-color: #FFF5F0;
}
.checkbox-wrapper {
  margin-right: 25rpx;
}
.shop-info {
  flex: 1;
}
.shop-id {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 5rpx;
}
.shop-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}
/* 删除按钮容器 */
.delete-btn-container {
  margin-top: 40rpx;
  padding: 0 20rpx;
}
/* 正常状态按钮 */
.delete-btn {
  width: 100%;
  height: 80rpx;
  background-color: #FF7A2F;
  color: white;
  font-size: 30rpx;
  border-radius: 50rpx;
  border: 2rpx solid #FF7A2F;
  /* 文字水平+垂直居中 */
  display: flex;
  align-items: center;
  justify-content: center;
  /* 清除默认样式 */
  box-shadow: none;
  outline: none;
  -webkit-tap-highlight-color: transparent;
}
/* 禁用状态按钮 */
.delete-btn[disabled] {
  background-color: #FFB88F;
  border-color: #FFB88F;
  color: white;
  opacity: 0.7;
}
