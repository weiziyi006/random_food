<view class="container">
  <view class="header">
    <text class="title">添加新菜品</text>
  </view>
  <view class="input-section">
    <input
      class="input"
      placeholder="请输入菜品大类名称"
      value="{{categoryName}}"
      bindinput="inputChange"
    />
    <button class="add-btn" bindtap="submitForm">添加</button>
  </view>
  <view class="list-section">
    <text class="list-title">已有的菜品大类</text>
    <view class="list-item" wx:for="{{categoryList}}" wx:key="categoryid">
      <text class="item-id">ID: {{item.categoryid}}</text>
      <text class="item-name">{{item.category_name}}</text>
    </view>
  </view>
</view>