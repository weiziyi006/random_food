<view class="container">
  <view class="content">
    <view wx:if="{{isloading}}" class="loading-wrap">
      <text class="loading-text">加载中...</text>
    </view>

    <view wx:elif="{{collectedshops.length === 0}}" class="empty-wrap">
      <view class="empty-icon">💔</view>
      <text class="empty-title">暂无收藏店铺</text>
      <text class="empty-desc">快去发现心仪的店铺吧～</text>
    </view>

    <view wx:else class="shop-list">
      <view 
        wx:for="{{collectedshops}}" 
        wx:key="shopid" 
        class="shop-item"
      >
        <view class="item-tag">❤️</view>
        <view class="shop-info">
          <text class="shop-name">{{item.shop_name}}</text>
          <text class="shop-address">{{item.address}}</text>
        </view>
        <view 
          class="cancel-collect-btn"
          data-shopid="{{item.shopid}}"
          data-shopname="{{item.shop_name}}"
          bindtap="onCancelCollectTap"
        >
          <text class="btn-text">取消收藏</text>
        </view>
      </view>
    </view>
  </view>
</view>