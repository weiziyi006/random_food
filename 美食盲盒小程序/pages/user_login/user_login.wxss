.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  min-height: 100vh;
  background-color: #f8f8f8;
}
.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
}
.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 20rpx;
}
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
}
.subtitle {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
}
.tab-bar {
  display: flex;
  width: 100%;
  margin-bottom: 40rpx;
  border-bottom: 1rpx solid #eee;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 32rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}
.tab-item.active {
  color: #f60;
  border-bottom-color: #f60;
}
.form {
  width: 100%;
  height: 100%;
}
.input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  background-color: #fff;
  font-size: 30rpx;
}
.code-input {
  display: flex;
  justify-content: space-between;
}
.get-code-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: rgb(236, 139, 75);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
}
.forget-password {
  display: block;
  text-align: right;
  font-size: 26rpx;
  color: #f60;
  margin-bottom: 40rpx;
}
.login-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background-color: rgb(240, 109, 48);
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  margin-bottom: 60rpx;
}
.links {
  text-align: center;
  font-size: 28rpx;
}
.link {
  display: block;
  color: #666;
  margin-bottom: 20rpx;
}
.admin-link {
  color: #f60;
}