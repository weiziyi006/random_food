page {
  margin: 0;
  padding: 0;
  width: 100%;
  height: 100vh;
  background: #fdfdfd;
}
.container {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 40rpx 30rpx 320rpx;
}
.bottom-foreground {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 300rpx;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}
.wave-shape {
  position: absolute;
  bottom: 0;
  border-radius: 50%;
  opacity: 0.8;
  overflow: hidden;
}
.wave-1 { left: -100rpx; width: 400rpx; height: 180rpx; background: #f4e1a3; }
.wave-2 { left: 200rpx;  width: 320rpx; height: 150rpx; background: #e8cd7e; }
.wave-3 { right: -80rpx; width: 420rpx; height: 190rpx; background: #f3c8b8; }
.food-card {
  position: absolute;
  bottom: -700rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  background: #fff;
  border-radius: 32rpx;
  box-shadow: 0 10rpx 40rpx rgba(229, 57, 53, 0.15);
  z-index: 10;
  box-sizing: border-box;
  padding: 40rpx 32rpx;
  transition: bottom 0.7s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.food-card.show {
  bottom: 270rpx;
}
.card-header {
  text-align: center;
  padding-bottom: 32rpx;
  border-bottom: 2rpx dashed #fef0f0;
  margin-bottom: 32rpx;
}
.header-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}
.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: rgba(238, 188, 159, 0.95);
  margin-bottom: 8rpx;
}
.card-content {
  width: 100%;
}
.info-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  margin-bottom: 36rpx;
}
.info-item:last-child {
  margin-bottom: 0;
}
.item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.bg-category { background: #fff2e8; color: #ff9800; }
.bg-shop { background: #e8f5e9; color: #4caf50; }
.bg-address { background: #e3f2fd; color: #2196f3; }
.item-wrap {
  flex: 1;
}
.item-label {
  font-size: 30rpx;
  color: #999;
  line-height: 30rpx;
}
.label-with-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  line-height: 30rpx;
}
.label-actions {
  display: flex;
  gap: 20rpx;
  align-items: center;
}
.item-value {
  font-size: 38rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.5;
  word-break: break-all;
}
.empty-tip {
  text-align: center;
  font-size: 32rpx;
  color: #999;
  padding: 80rpx 0;
}
.card-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
  margin-bottom: 24rpx;
}
.btn {
  flex: 1;
  height: 96rpx;
  border-radius: 48rpx;
  border: none;
  background: linear-gradient(135deg, #fff5f5, #ffebee);
  color: #E53935;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(229, 57, 53, 0.2);
  transition: all 0.3s ease;
  padding: 0;
}
.btn-food {
  background: linear-gradient(135deg, #fff2e8, #ffe0b2);
  color: #f57c00;
  border: 1rpx solid#f57c00;
}
.btn-shop {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  color: #388e3c;
  border: 1rpx solid#388e3c;
}
.btn-text {
  font-size: 32rpx;
}
.btn:active {
  transform: translateY(3rpx);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.card-footer {
  width: 100%;
}
.btn-back {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  border: 2rpx solid #E53935;
  background: #fff;
  color: #E53935;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  padding: 0;
}
.back-text {
  font-size: 32rpx;
}
.btn-back:active {
  background: #fef0f0;
  transform: translateY(3rpx);
}
.fairy-container {
  position: absolute;
  top: 40rpx;       
  left: 30rpx;  
  z-index: 20;
  animation: float 3s ease-in-out infinite;
}
.fairy-img {
  width: 200rpx; 
  height: auto;
  display: block;
}
.fairy-speech {
  position: absolute;
  top: -200rpx;
  left: 220rpx;
  background: rgba(252, 241, 233, 0.95);
  color: #000000;
  padding: 30rpx 40rpx;
  border-radius: 32rpx;
  font-size: 30rpx; 
  box-shadow: 0 6rpx 16rpx rgba(249, 243, 239, 0.95);
  min-width: 200rpx;
  max-width: 380rpx;
  text-align: center;
  position: relative;
  word-wrap: break-word;
  word-break: break-all;
  white-space: normal; 
}
.fairy-speech::after {
  content: '';
  position: absolute;
  left: -14rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border-width: 10rpx 14rpx 10rpx 0;
  border-style: solid;
  border-color: transparent rgba(249, 243, 239, 0.95) transparent transparent;
}
@keyframes float {
  0% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
  100% { transform: translateY(0); }
}