.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding: 60rpx 40rpx;
}
.header {
  text-align: center;
  margin-bottom: 80rpx;
}
.title {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}
.subtitle {
  font-size: 28rpx;
  color: #999;
}
.stats-row {
  display: flex;
  justify-content: space-between;
  gap: 30rpx;
  margin-bottom: 80rpx;
}
.stat-card {
  flex: 1;
  background: white;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.food-card {
  border-left: 8rpx solid #ff6b35;
}
.shop-card {
  border-left: 8rpx solid #ff6b35;
}
.stat-icon {
  font-size: 60rpx;
}
.stat-label {
  display: block;
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}
.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6b35;
}
.section {
  margin-bottom: 60rpx;
}
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #ff6b35;
}
.btn-group {
  display: flex;
  gap: 20rpx;
  border:none;
}
.btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary {
  background: #ff6b35;
  color: white;
}
.btn-outline {
  background: white;
  color: #ff6b35;
}
.btn-back {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: transparent;
  color: #999;
  border-radius: 8rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}