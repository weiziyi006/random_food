.container {
  padding: 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}
.header {
  text-align: center;
  margin-bottom: 40rpx;
}
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}
.input-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 50rpx;
  background-color: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.input {
  flex: 1;
  padding: 18rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}
.add-btn {
  background-color: #ff6b35;
  color: #fff;
  font-size: 28rpx;
  padding: 0 30rpx;
  border-radius: 8rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.list-section {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.list-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #eee;
}
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.list-item:last-child {
  border-bottom: none;
}
.item-id {
  font-size: 26rpx;
  color: #ff6b35;
  font-weight: 500;
}
.item-name {
  font-size: 28rpx;
  color: #333;
}