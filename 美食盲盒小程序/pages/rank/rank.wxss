.container {
  background: #fff5f5;
  min-height: 100vh;
  padding: 20rpx 30rpx;
}
.slogan {
  margin: 30rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
}
.top-three {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 40rpx;
}
.podium-card {
  flex: 1;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  color: #333;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}
.podium-card.first {
  background: linear-gradient(135deg, #fff9e6, #ffecb3);
  border: 2rpx solid #ffd700;
}
.podium-card.second {
  background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
  border: 2rpx solid #c0c0c0;
}
.podium-card.third {
  background: linear-gradient(135deg, #fbe9d7, #f3d7bd);
  border: 2rpx solid #cd7f32;
}

.podium-card .badge {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}
.podium-card .shop-name {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}
.podium-card .cate {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 16rpx;
}
.podium-card .score-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.podium-card .star {
  font-size: 28rpx;
  color: #ffcc33;
}
.podium-card .score {
  font-size: 26rpx;
  font-weight: 500;
}
.rank-list {
  margin-top: 20rpx;
}
.rank-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.shop-info {
  flex: 1;
}
.cate {
  font-size: 24rpx;
  color: #ff6b6b;
  margin-bottom: 8rpx;
}
.shop {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.addr {
  font-size: 26rpx;
  color: #666;
}
.score-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.star {
  font-size: 32rpx;
  color: #ffcc33;
}
.score {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}