.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff5f5 0%, #f8f8f8 100%);
}
.content {
  padding: 0 30rpx 60rpx;
  padding-top: 40rpx;
}
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 0;
  gap: 20rpx;
}
.loading-text {
  font-size: 28rpx;
  color: #999;
}
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 0;
  gap: 20rpx;
}
.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}
.empty-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}
.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.shop-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 20rpx;
}
.shop-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.1);
  gap: 20rpx;
}
.item-tag {
  font-size: 32rpx;
}
.shop-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.shop-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.shop-address {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}
.cancel-collect-btn {
  padding: 12rpx 24rpx;
  background-color: #fff5f5;
  border: 1rpx solid #ff6b6b;
  border-radius: 24rpx;
}
.cancel-collect-btn .btn-text {
  font-size: 26rpx;
  color: #ff6b6b;
}
.cancel-collect-btn:active {
  background-color: #ffe6e6;
}